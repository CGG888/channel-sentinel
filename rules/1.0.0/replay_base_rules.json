{
  "meta": {
    "rules_version": "2026.03.17-base-contract-v2",
    "engine_min_version": "1.0.0",
    "engine_max_version": "2.x",
    "updated_at": "2026-03-21T00:00:00+08:00",
    "schema_version": "1.0.0",
    "description": "回放基础地址规则（默认采用单播直播地址，规则仅处理差异场景）",
    "notes": [
      "本文件仅负责从直播单播地址生成回放基础地址，不负责时间参数拼接",
      "时间参数规则应由 time_placeholder_rules.json 管理",
      "当频道已手工设置回放基础地址时，手工值优先于本规则",
      "默认基线为使用直播单播地址，只有回放基址与直播地址不一致时才命中规则"
    ],
    "changelog": [
      {
        "version": "2026.03.17-base-contract-v2",
        "date": "2026-03-17",
        "changes": [
          "补充 schema_version 与 changelog 契约字段",
          "明确 defaults 优先级与失败行为",
          "为统一规则中心接入保留兼容字段"
        ]
      },
      {
        "version": "2026.03.21",
        "date": "2026-03-21",
        "changes": [
          "新增广东电信RTSP回放规则"
        ]
      }
    ]
  },
  "defaults": {
    "fallback_policy": "use_live_url",
    "query_mode": "keep_all",
    "priority_order": [
      "manual_override",
      "default_baseline",
      "region_rule",
      "protocol_rule",
      "fallback_policy"
    ],
    "on_no_match": "use_live_url",
    "error_on_invalid_template": true
  },
  "rules": [
    {
      "id": "hn-ct-http-unicast-v1",
      "enabled": true,
      "priority": 100,
      "scope": "internal",
      "region": {
        "province": "湖南",
        "city": "*",
        "operator": "电信http"
      },
      "match": {
        "stream_type": "unicast",
        "protocols": [
          "http",
          "https"
        ],
        "host_regex": ".*",
        "path_regex": "^/000000002000/.+/.+\\.m3u8$"
      },
      "transform": {
        "base_from": "live_url",
        "query_mode": "drop_all",
        "query_whitelist": [],
        "query_blacklist": [
          "starttime",
          "endtime",
          "begin",
          "end",
          "playseek",
          "npt"
        ],
        "output_template": "{live_base}"
      },
      "examples": [
        {
          "input": "http://124.232.231.172:8089/000000002000/201500000219/index.m3u8?zte_offset=30&ispcode=2&starttime=",
          "output": "http://124.232.231.172:8089/000000002000/201500000219/index.m3u8"
        }
      ]
    },
    {
      "id": "gd-ct-rtsp-unicast-v1",
      "enabled": true,
      "priority": 100,
      "scope": "internal",
      "region": {
        "province": "广东",
        "city": "*",
        "operator": "电信rtsp（测试）"
      },
      "match": {
        "stream_type": "unicast",
        "protocols": [
          "rtsp"
        ],
        "host_regex": ".*",
        "path_regex": "^/live/.+/.+\\.m3u8$"
      },
      "transform": {
        "base_from": "live_url",
        "query_mode": "drop_all",
        "query_whitelist": [],
        "query_blacklist": [
          "starttime",
          "endtime",
          "begin",
          "end",
          "playseek",
          "npt"
        ],
        "output_template": "{live_base}"
      },
      "examples": [
        {
          "input": "rtsp://58.253.78.142:554/live/1/10960009342103630629.m3u8?starttime=",
          "output": "rtsp://58.253.78.142:554/live/1/10960009342103630629.m3u8"
        }
      ]
    }
  ]
}