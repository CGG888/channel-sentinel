{
  "name": "channel-sentinel",
  "version": "2.0.0",
  "description": "Channel Monitoring & Status Guardian Platform",
  "license": "MIT",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build:qier": "esbuild frontend/qier-player-entry.js --bundle --loader:.css=css --format=iife --global-name=IptvQierPlayer --minify --outfile=public/js/iptv-qier-player.bundle.js",
    "smoke:http": "node src/utils/http-smoke.js",
    "smoke:http:strict": "node src/utils/http-smoke.js --strict",
    "test:stream-service": "node src/utils/stream-service-tests.js",
    "test:auth-service": "node src/utils/auth-service-tests.js",
    "test:contract:player-auth": "node src/utils/player-auth-contract-tests.js",
    "test:contract:export-proxy": "node src/utils/export-proxy-contract-tests.js",
    "test:contract:system-authz": "node src/utils/system-authz-contract-tests.js",
    "test:contract:ops-governance": "node src/utils/ops-governance-contract-tests.js",
    "gate:services": "node src/utils/service-quality-gate.js",
    "gate:services:with-server": "node src/utils/run-service-gate-with-server.js",
    "gate:full:with-server": "node src/utils/run-service-gate-with-server.js && node src/utils/service-gate-trend.js && node src/utils/service-gate-notify.js && node src/utils/ops-domain-sop.js && node src/utils/ops-low-frequency-governance.js && node src/utils/final-acceptance-report.js",
    "trend:service-gate": "node src/utils/service-gate-trend.js",
    "notify:service-gate": "node src/utils/service-gate-notify.js",
    "ops:domain:sop": "node src/utils/ops-domain-sop.js",
    "ops:low-frequency": "node src/utils/ops-low-frequency-governance.js",
    "ops:governance": "node src/utils/ops-domain-sop.js && node src/utils/ops-low-frequency-governance.js",
    "report:final-acceptance": "node src/utils/final-acceptance-report.js",
    "test:ops-observability": "node src/utils/ops-observability-tests.js",
    "db:reconcile": "node src/utils/reconcile-storage.js",
    "db:reconcile:strict": "node -e \"process.env.STRICT_RECONCILE='true'; require('./src/utils/reconcile-storage');\"",
    "db:smoke": "node src/utils/db-smoke.js",
    "db:smoke:sqlite": "node -e \"process.env.STORAGE_MODE='sqlite'; process.env.READ_FROM='sqlite'; require('./src/utils/db-smoke');\""
  },
  "dependencies": {
    "axios": "^1.13.5",
    "body-parser": "^1.20.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dns-packet": "^5.6.1",
    "express": "^4.18.2",
    "fast-xml-parser": "^4.4.1",
    "ip": "^2.0.1",
    "sharp": "^0.34.5",
    "sqlite3": "^5.1.7",
    "svg-captcha": "^1.4.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "hls.js": "^1.6.15",
    "mpegts.js": "^1.8.0",
    "nodemon": "^3.0.2",
    "qier-player": "^2.0.3"
  }
}
